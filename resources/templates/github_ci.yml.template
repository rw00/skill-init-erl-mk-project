name: Erlang CI

on:
  push:
    branches: [ main ]
  pull_request:
    branches: [ main ]

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
    - uses: actions/checkout@v3
    - name: Install Erlang
      run: sudo apt-get update && sudo apt-get install -y erlang
    - name: Build
      run: make local
